{
  "title": "Homelab AI Stack",
  "uid": "homelab-ai",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "RAG Requests Total",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rag_requests_total)",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Agent Requests Total",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(agent_requests_total)",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Host Memory Usage %",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "unit": "percent"
      },
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Host CPU Usage %",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "RAG Request Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(rag_requests_total[5m])",
          "legendFormat": "{{endpoint}} - {{status}}",
          "datasource": "Prometheus"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 6,
      "title": "Agent Tool Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "agent_tool_usage_total",
          "legendFormat": "{{tool}}",
          "datasource": "Prometheus"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 7,
      "title": "RAG Query Latency (p50/p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(rag_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rag_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 8,
      "title": "Agent Request Latency (p50/p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(agent_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, rate(agent_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": "Prometheus"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 9,
      "title": "Chunks Ingested Total",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "rag_chunks_ingested_total",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "datasource": "Prometheus"
    },
    {
      "id": 10,
      "title": "Host Disk Usage %",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 20
      },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
          "datasource": "Prometheus"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "datasource": "Prometheus"
    }
  ],
  "schemaVersion": 38
}